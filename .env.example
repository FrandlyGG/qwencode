# Токен бота от @BotFather
TG_BOT_TOKEN=your_bot_token_here

# Токен API Wildberries (получить в личном кабинете селлера, категория "Поставки")
WB_API_TOKEN=your_wb_api_token_here

# ID чата для уведомлений (можно оставить пустым - бот будет отправлять тому, кто запустил команду)
TG_CHAT_ID=

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# Интервал проверки в секундах (не обязательно)
CHECK_INTERVAL=30
