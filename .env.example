# Токен API Wildberries (получить в личном кабинете селлера)
WB_API_TOKEN=your_wildberries_api_token_here

# Токен Telegram бота (получить у @BotFather)
TG_BOT_TOKEN=your_telegram_bot_token_here

# ID чата для уведомлений (можно узнать у @userinfobot или из группы)
TG_CHAT_ID=your_chat_id_here

# Интервал проверки складов в секундах (по умолчанию 60)
CHECK_INTERVAL=60

# ID складов для мониторинга (через запятую, оставьте пустым для всех)
MONITOR_WAREHOUSE_IDS=

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Файл для логов
LOG_FILE=wb_monitor.log
